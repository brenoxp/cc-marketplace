#!/usr/bin/env bash
SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
# Drop bun's unimplemented-ws-event warnings (noise from playwright CDP over bun),
# keep every other stderr line and preserve the exit code.
exec bun "$SCRIPT_DIR/../server/src/cli.ts" "$@" \
  2> >(grep -v -F "[bun] Warning: ws.WebSocket" >&2)
